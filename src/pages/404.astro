---
import BaseLayout from '@layouts/BaseLayout.astro';
import { SITE_NAME } from '../config';
---

<BaseLayout title="Not Found" noindex={true}>
  <div class="flex min-h-[60vh] flex-col items-center justify-center px-4 text-center">
    <h1 class="font-display text-6xl font-bold text-outline">404</h1>
    <p class="mt-4 text-lg text-on-surface-variant">Page not found</p>
    <a
      href="/"
      class="mt-8 rounded-lg bg-primary px-6 py-3 text-sm font-medium text-on-primary transition-colors hover:opacity-90"
    >
      Back to {SITE_NAME}
    </a>
  </div>
</BaseLayout>
