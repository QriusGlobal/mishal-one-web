---
/**
 * Landing page — linktree-style.
 * Avatar, name, tagline, social links, link cards.
 */

import BaseLayout from '@layouts/BaseLayout.astro';
import StructuredData from '@components/StructuredData.astro';
import { SITE_NAME, SITE_TAGLINE, SITE_URL, SOCIAL_LINKS, LINK_ITEMS } from '../config';

const personSchema = {
  name: SITE_NAME,
  url: SITE_URL,
  jobTitle: SITE_TAGLINE,
  sameAs: SOCIAL_LINKS.map((s) => s.url),
};
---

<BaseLayout noindex={true}>
  <StructuredData type="Person" data={personSchema} />

  <section class="mx-auto flex max-w-md flex-col items-center px-6 py-16 text-center">
    <!-- Avatar placeholder -->
    <div
      class="flex h-24 w-24 items-center justify-center rounded-full bg-primary text-3xl font-bold text-on-primary font-display"
      aria-label="Avatar"
    >
      {SITE_NAME.charAt(0).toLowerCase()}
    </div>

    <!-- Name & tagline -->
    <h1 class="mt-6 font-display text-2xl font-bold text-on-background">
      {SITE_NAME}
    </h1>
    <p class="mt-1 text-on-surface-variant">{SITE_TAGLINE}</p>

    <!-- Social links -->
    <div class="mt-6 flex gap-4">
      {SOCIAL_LINKS.map(({ label, url }) => (
        <a
          href={url}
          target="_blank"
          rel="noopener noreferrer"
          class="rounded-full border border-outline px-4 py-2 text-sm text-on-surface-variant transition-colors hover:border-primary hover:text-primary"
          aria-label={label}
        >
          {label}
        </a>
      ))}
    </div>

    <!-- Link cards -->
    <div class="mt-10 flex w-full flex-col gap-3">
      {LINK_ITEMS.map(({ title, description, url, badge }) => (
        <a
          href={url}
          target="_blank"
          rel="noopener noreferrer"
          class="group flex items-center justify-between rounded-lg border border-outline-variant bg-surface px-5 py-4 transition-all hover:border-primary hover:shadow-sm"
        >
          <div class="text-left">
            <span class="text-sm font-medium text-on-surface group-hover:text-primary transition-colors">
              {title}
            </span>
            {description && (
              <span class="mt-0.5 block text-xs text-on-surface-variant">{description}</span>
            )}
          </div>
          {badge && (
            <span class="rounded-full bg-accent px-2.5 py-0.5 text-xs font-semibold text-on-accent">
              {badge}
            </span>
          )}
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
