---
/**
 * Landing page — linktree-style.
 * Full Navy canvas, Gold accents, clear card elevation.
 * Designed to work identically in light and dark mode.
 */

import { Picture } from 'astro:assets';
import BaseLayout from '@layouts/BaseLayout.astro';
import StructuredData from '@components/StructuredData.astro';
import { Icon } from 'astro-icon/components';
import { SITE_NAME, SITE_TAGLINE, SITE_URL, SOCIAL_LINKS, LINK_ITEMS } from '../config';
import profileImage from '@assets/images/mish-profile.jpg';

const personSchema = {
  name: SITE_NAME,
  url: SITE_URL,
  jobTitle: SITE_TAGLINE,
  sameAs: SOCIAL_LINKS.map((s) => s.url),
};

const socialIcons: Record<string, string> = {
  'X': 'lucide:twitter',
  'GitHub': 'lucide:github',
  'Qrius GitHub': 'lucide:building-2',
  'LinkedIn': 'lucide:linkedin',
  'Email': 'lucide:mail',
};
---

<BaseLayout noindex={true}>
  <StructuredData type="Person" data={personSchema} />

  <div class="min-h-screen bg-navy-900">
    <div class="mx-auto flex max-w-md flex-col items-center px-6 py-20 text-center">

      <!-- Profile photo — optimized to AVIF/WebP with JPEG fallback -->
      <div class="relative">
        <Picture
          src={profileImage}
          formats={['avif', 'webp']}
          alt={SITE_NAME}
          width={224}
          height={224}
          quality={85}
          class="h-28 w-28 rounded-full border-4 border-gold-500 object-cover"
          loading="eager"
        />
      </div>

      <!-- Name & tagline -->
      <h1 class="mt-8 font-display text-4xl font-bold text-white">
        {SITE_NAME}
      </h1>
      <p class="mt-2 text-lg text-navy-100">{SITE_TAGLINE}</p>

      <!-- Social links — icon buttons in a row -->
      <div class="mt-8 flex flex-wrap justify-center gap-3">
        {SOCIAL_LINKS.map(({ label, url }) => (
          <a
            href={url}
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center gap-2 rounded-full bg-navy-700 px-4 py-2.5 text-sm font-medium text-white transition-all hover:bg-gold-500 hover:text-navy-900"
            aria-label={label}
          >
            {socialIcons[label] && (
              <Icon name={socialIcons[label]} class="h-4 w-4" />
            )}
            {label}
          </a>
        ))}
      </div>

      <!-- Divider -->
      <div class="mt-12 h-px w-16 bg-navy-500"></div>

      <!-- Link cards -->
      <div class="mt-12 flex w-full flex-col gap-4">
        {LINK_ITEMS.map(({ title, description, url, icon, badge }) => (
          <a
            href={url}
            class="group flex items-center gap-4 rounded-xl border border-navy-500 bg-navy-700 px-5 py-5 transition-all hover:border-gold-500 hover:bg-navy-700/80"
          >
            {icon && (
              <div class="flex h-11 w-11 shrink-0 items-center justify-center rounded-lg bg-gold-500 text-navy-900">
                <Icon name={icon} class="h-5 w-5" />
              </div>
            )}
            <div class="flex-1 text-left">
              <span class="text-base font-semibold text-white group-hover:text-gold-400 transition-colors">
                {title}
              </span>
              {description && (
                <span class="mt-0.5 block text-sm text-navy-100">{description}</span>
              )}
            </div>
            {badge && (
              <span class="rounded-full bg-gold-500 px-3 py-1 text-xs font-bold text-navy-900">
                {badge}
              </span>
            )}
            <Icon name="lucide:arrow-right" class="h-5 w-5 text-navy-300 transition-colors group-hover:text-gold-500" />
          </a>
        ))}
      </div>

    </div>
  </div>
</BaseLayout>
