---
/**
 * Blog listing page — shows all published posts.
 */

import BaseLayout from '@layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf());
---

<BaseLayout title="Blog" description="Essays and writing by Mishal.">
  <section class="mx-auto max-w-2xl px-6 py-12">
    <h1 class="font-display text-3xl font-bold text-primary">Blog</h1>
    <p class="mt-2 text-on-surface-variant">Essays, notes, and thinking out loud.</p>

    <ul class="mt-10 space-y-8">
      {posts.map((post) => (
        <li>
          <a href={`/blog/${post.id}/`} class="group block">
            <h2 class="font-display text-xl font-semibold text-on-surface group-hover:text-primary transition-colors">
              {post.data.title}
            </h2>
            <p class="mt-1 text-sm text-on-surface-variant">{post.data.description}</p>
            <time
              datetime={post.data.publishDate.toISOString()}
              class="mt-2 block text-xs text-neutral-500"
            >
              {post.data.publishDate.toLocaleDateString('en-AU', {
                year: 'numeric',
                month: 'long',
                day: 'numeric',
              })}
            </time>
          </a>
        </li>
      ))}
    </ul>

    {posts.length === 0 && (
      <p class="mt-10 text-on-surface-variant">No posts yet.</p>
    )}
  </section>
</BaseLayout>
