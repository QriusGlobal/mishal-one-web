---
/**
 * BaseHead — SEO, AEO, and metadata for every page.
 *
 * Renders: charset, viewport, title, description, canonical,
 * Open Graph, Twitter Cards, robots, sitemap, RSS discovery,
 * and WebSite JSON-LD schema.
 */

import { SITE_NAME, SITE_URL, SITE_DESCRIPTION } from '../config';

export interface Props {
  title?: string;
  description?: string;
  image?: string;
  type?: 'website' | 'article';
  noindex?: boolean;
  publishDate?: string;
  updateDate?: string;
}

const {
  title,
  description = SITE_DESCRIPTION,
  image = '/og-placeholder.png',
  type = 'website',
  noindex = false,
  publishDate,
  updateDate,
} = Astro.props;

const fullTitle = title ? `${title} — ${SITE_NAME}` : SITE_NAME;
const canonicalURL = new URL(Astro.url.pathname, Astro.site).toString();
const ogImageURL = new URL(image, Astro.site).toString();
const robotsContent = noindex ? 'noindex, nofollow' : 'index, follow';

const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: SITE_NAME,
  url: SITE_URL,
  description: SITE_DESCRIPTION,
};
---

<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />

<!-- Title & Description -->
<title>{fullTitle}</title>
<meta name="description" content={description} />

<!-- Robots -->
<meta name="robots" content={robotsContent} />
<meta name="max-snippet" content="-1" />

<!-- Canonical -->
<link rel="canonical" href={canonicalURL} />

<!-- Favicon -->
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<meta name="generator" content={Astro.generator} />

<!-- Open Graph -->
<meta property="og:title" content={fullTitle} />
<meta property="og:description" content={description} />
<meta property="og:image" content={ogImageURL} />
<meta property="og:url" content={canonicalURL} />
<meta property="og:type" content={type} />
<meta property="og:site_name" content={SITE_NAME} />

<!-- Twitter Card -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={fullTitle} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImageURL} />

<!-- Article dates (if provided) -->
{publishDate && <meta property="article:published_time" content={publishDate} />}
{updateDate && <meta property="article:modified_time" content={updateDate} />}

<!-- Discovery -->
<link rel="sitemap" href="/sitemap-index.xml" />
<link rel="alternate" type="application/rss+xml" href="/rss.xml" title={`${SITE_NAME} RSS`} />

<!-- WebSite JSON-LD -->
<script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />

<!-- Named slot for page-specific head content (extra JSON-LD, etc.) -->
<slot name="head" />
