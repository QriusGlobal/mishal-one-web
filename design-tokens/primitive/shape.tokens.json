{
  "radius": {
    "$type": "dimension",
    "$description": "Border radius scale — maps to Tailwind rounded-* utilities",
    "none": { "$value": "0px" },
    "sm":   { "$value": "0.25rem" },
    "md":   { "$value": "0.5rem" },
    "lg":   { "$value": "0.75rem" },
    "xl":   { "$value": "1rem" },
    "2xl":  { "$value": "1.25rem" },
    "full": { "$value": "9999px" }
  }
}
