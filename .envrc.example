# mishal-one-web — all secrets pulled from BWS at runtime
# Requires: bws CLI, macOS Keychain entry "bws-access-token", direnv
#
# Setup:
#   cp .envrc.example .envrc
#   direnv allow .

export BWS_ACCESS_TOKEN="${BWS_ACCESS_TOKEN:-$(security find-generic-password -s "bws-access-token" -w)}"

# Cloudflare
export CLOUDFLARE_ACCOUNT_ID="$(bws secret get 0db787a0-3ae5-4d1c-85b9-b425003337c7 --output json | jq -r '.value')"
export CLOUDFLARE_ZONE_ID="$(bws secret get a5ccfe32-1034-4927-9778-b42500333fe0 --output json | jq -r '.value')"
# export CLOUDFLARE_API_TOKEN="$(bws secret get <SECRET_ID> --output json | jq -r '.value')"  # TODO: create token with DNS write, store in BWS
